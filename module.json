{
    "name": "KODI",
    "type": "WebSocket Client",
    "path": "ToCenTek",
    "version": "1.1.0",
    "description": "通过 WebSocket 控制 KODI, 基于 KODI Websocket API v13.0.0 版本.\nControl KODI by Websocket. Based on KODI Websocket API v13.0.0",
    "url": "https://kodi.wiki/view/JSON-RPC_API/v13",
    "downloadURL": "",
    "hasInput": true,
    "hasOutput": true,
    "hideDefaultCommands": true,
    "defaults": {
        "Protocol": "Lines",
        "autoAdd": false,
        "serverPath": "10.0.0.41:9090"
    },
    "parameters": {
        "Initialization": {
            "type": "Trigger",
            "description": "初始化, 加载视频播放列表.\nInitialize, load playlist."
        },
        "Sync Enabled":{
            "description": "启用多设备同步.\nEnable multi-device sync.",
            "type": "Boolean",
            "default": false
        }
    },
    "values":{
        "Info":{
            "type": "Container",
            "collapsed": true,
            "isPaused":{
                "type":"Boolean",
                "readOnly": true,
                "description": "是否已暂停.\nWhether media is paused or not."
            },
            "Play/Pause":{
                "description": "切换播放/暂停.\nToggle Play/Pause.",
                "type": "Trigger"
            },
            "Playing":{
                "description": "当前正在播放的媒体文件路径.\nPath to the Currently Playing File.",
                "type":"String",
                "default": ""
            },
            "Items":{
                "description": "当前播放列表中的所有媒体项.\nAutomatically Retrieve from the Current playlist.",
                "type":"String",
                "multiline": true,
                "readOnly": true
            },
            "isLooped":{
                "type":"Boolean",
                "readOnly": true,
                "description": "false = 不循环当前媒体, 但循环列表.\ntrue = 循环播放当前媒体.\nWhether media is looped or not."
            },
            "Random":{
                "type": "Boolean",
                "readOnly": true
            },
            "Volume":{
                "description": "音量.\nCurrent Volume Level.",
                "type":"Float",
                "ui": "slider",
                "min": 0.0,
                "max": 100.0,
                "default": 60.0
            },
            "isMuted":{
                "type": "Boolean",
                "readOnly": true
            }
        },
        "Synchronizer":{
            "type": "Container",
            "collapsed": true,
            "HTTP User":{
                "description": "KODI HTTP 用户名.\nKODI HTTP username.",
                "type": "String",
                "default": "kodi"
            },
            "HTTP Pass":{
                "description": "KODI HTTP 密码.\nKODI HTTP password.",
                "type": "String",
                "default": "tocentek"
            },
                "Sync Interval":{
                    "description": "位置轮询间隔（毫秒）.\nPosition polling interval (ms).",
                    "type": "Integer",
                    "min": 4,
                    "default": 500
                },
                "Sync Threshold":{
                    "description": "允许的最大偏移（毫秒），超过则纠偏.\nMax allowed drift (ms).",
                    "type": "Integer",
                    "min": 4,
                    "default": 8
                },
            "Sync Status":{
                "description": "同步状态.\nSync status.",
                "type": "String",
                "readOnly": true,
                "default": "Idle"
            },
            "KODIs":{
                "type": "Container",
                "collapsed": false,
                "Secondary":{
                    "description": "副 KODI 的 IP:port 列表, 每行一个.\nSecondary KODI IP:port list, one per line.",
                    "type": "String",
                    "multiline": true,
                    "default": ""
                },
                "Drift":{
                    "description": "各副机漂移值(ms)。\nDrift values per secondary (ms).",
                    "type": "String",
                    "readOnly": true,
                    "default": ""
                }
            }
        }
    },
    
    "scripts": ["kodi.js"],

    "commands": {
        "Initialization":{
            "menu": "",
            "description": "初始化, 加载视频播放列表\nInitialization, Load Playlist",
            "callback": "init"
        },
        "Send Raw JSON": {
            "menu": "",
            "description": "发送原始 JSON-RPC 命令到所有 KODI.\nSend raw JSON-RPC command to all KODIs.",
            "callback": "sendJSON",
            "parameters": {
                "JSON": {
                    "description": "完整且符合 KODI JSON-RPC 规范的命令字符串.\nComplete Command String Conforming to the KODI JSON-RPC Specification.",
                    "type": "String",
                    "default":"{\"jsonrpc\":\"2.0\",\"method\":\"Application.GetProperties\",\"params\":{\"properties\":[\"volume\",\"muted\"]},\"id\":\"test\"}"
                }
            }
        },

        "Index": {
            "menu": "Player",
            "description": "播放指定索引的媒体项.\nPlay Media Item at Index",
            "callback": "playIndex",
            "parameters": {
                "Index":{
                    "description": "要播放的媒体项在当前播放列表中的索引.\nIndex of the media item in the current playlist to play.",
                    "type": "Integer",
                    "default": 0,
                    "min": 0
                }
            }
        },
        "Next": {
            "menu": "Player",
            "description": "下一曲.\nNext track.",
            "callback": "nextTrack"
        },
        "Previous": {
            "menu": "Player",
            "description": "上一曲.\nPrevious track.",
            "callback": "prevTrack"
        },
        "Play||Pause": {
            "menu": "Player",
            "description": "Toggle Play/Pause\n播放/暂停",
            "callback": "playPause",
            "parameters": {
                "isPaused":{
                    "description": "是否暂停",
                    "type": "Boolean"
                }
            }
        },
        "Stop": {
            "menu": "Player",
            "description": "停止播放, 回到系统界面.\n初始化可重新播放\nStop Playback",
            "callback": "stopPlay"
        },
        "File": {
            "menu": "Player",
            "description": "播放指定路径的媒体文件.\nPlay Media File at Path",
            "callback": "playFile",
            "parameters": {
                "FilePath":{
                    "type": "String",
                    "default": "/storage/videos/***.mp4",
                    "description": "要播放的媒体文件的路径.\nPath to the media file to play."
                }
            }
        },

        "Mute":{
            "menu": "Volume",
            "callback": "mute",
            "parameters": {
                "Mute":{
                    "type": "Boolean"
                }
            }
        },
        "Set Volume": {
            "menu": "Volume",
            "description": "设置音量.\nSet Volume",
            "callback": "setVolume",
            "parameters": {
                "Volume":{
                    "description": "音量级别.\nVolume Level.",
                    "type": "Integer",
                    "min": 0,
                    "max": 100,
                    "default": 68
                }
            }
        },
        "Volume UP":{
            "menu": "Volume",
            "description": "音量递增.\nVolume increment",
            "callback": "volumeUP"
        },
        "Volume Down":{
            "menu": "Volume",
            "description": "音量递减.\nVolume decrement",
            "callback": "volumeDown"
        },

        "Seek": {
            "menu": "Playback",
            "description": "快进/快退.\nForward or Backward",
            "callback": "seek",
            "parameters": {
                "Step":{
                    "description": "快进或快退的时间步长, 单位为秒.\nForward: positive, e.g. 30\nBackward: negative, e.g. -30",
                    "type": "Integer",
                    "default": 30
                }
            }
        },
        "Seek To Parameters": {
            "menu": "Playback",
            "description": "跳转到百分比.\nSeek To Percentage",
            "callback": "seekToParameters",
             "parameters": {
                "Parameters": {
                    "description": "要跳转到的百分比.\nSeek to percentage.",
                    "type": "Integer",
                    "min": 0,
                    "default": 15
                }
            }
        },
        "Seek To Time": {
            "menu": "Playback",
            "description": "跳转到指定时间.\nSeek To Time",
            "callback": "seekToTime",
            "parameters": {
                "Hours":{
                    "description": "小时.\nHours.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Minutes":{
                    "description": "分钟.\nMinutes.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Seconds":{
                    "description": "秒.\nSeconds.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Milliseconds":{
                    "description": "毫秒.\nMilliseconds.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                }
            }
        },
        "Seek To Predefined": {
            "menu": "Playback",
            "description": "跳转到预设步进.\nSeek To Predefined Step",
            "callback": "seekToPredefined",
            "parameters": {
                "Step": {
                    "description": "预定义步进.\nPredefined step.",
                    "type": "Enum",
                    "options": {
                        "BigForward": "bigforward",
                        "SmallForward": "smallforward",
                        "BigBackward": "bigbackward",
                        "SmallBackward": "smallbackward"
                    }
                }
            }
        },
        "Loop": {
            "menu": "Playback",
            "description": "设置循环模式.\nSet Repeat Mode",
            "callback": "setLoop",
            "parameters": {
                "Mode":{
                    "description": "循环模式:\none = 循环当前媒体\noff = 不循环\nall = 循环列表\nRepeat mode:\none = Repeat Current\noff = Off\nall = Repeat All",
                    "type": "Enum",
                    "options": {
                        "One": "one",
                        "All": "all",
                        "Off": "off"
                    }
                }   
            }
        },
        "Random": {
            "menu": "Playback",
            "description": "设置随机播放.\nSet Shuffle",
            "callback": "setRandom",
            "parameters": {
                "Random":{
                    "type": "Boolean",
                    "default": false,
                    "description": "是否启用随机播放.\nWhether to enable shuffle mode."
                }   
            }
        }, 

        "Toggle Sync":{
            "menu": "Sync",
            "description": "开启/关闭多设备同步.\nEnable/disable multi-device sync.",
            "callback": "toggleSync"
        },
        "ReSync Now":{
            "menu": "Sync",
            "description": "立即轮询所有 KODI 的位置并纠偏.\nPoll all KODI positions and correct drift now.",
            "callback": "reSync"
        },

        "Restart KODI": {
            "menu": "System",
            "description": "仅重启 KODI, 不重启设备.\nOnly Restart KODI, Not the Whole Device.",
            "callback": "restartKODI"
        },
        "Standby": {
            "menu": "System",
            "description": "将远程媒体中心置于待机状态.\nPut the Remote Media Center into Standby Mode.",
            "callback": "standby"
        },
        "Reboot": {
            "menu": "System",
            "description": "重启远程媒体中心.\nReboot the Remote Media Center.",
            "callback": "reboot"
        },
        "Shutdown": {
            "menu": "System",
            "description": "关闭远程媒体中心.\nShutdown the Remote Media Center.",
            "callback": "shutdown"
        },
        "Show Info":{
            "menu": "System",
            "description": "切换 debug 消息显示.\nToggle debug overlay info.",
            "callback": "showInfo",
            "parameters":{
                "Show":{
                    "type": "Boolean"
                }
            }
        },
        "Show Notification": {
            "menu": "System",
            "description": "显示通知.\nShow Notification",
            "callback": "showNotification",
            "parameters": {
                "Title": {
                    "description": "通知的标题.\nNotification Title.",
                    "type": "String",
                    "default": "Hello"
                },
                "Message":{
                    "description": "通知信息或文本文件路径.\nNotification Message or text file path.",
                    "type": "File",
                    "default": "Browse to a text File and Enter text into it."
                },
                "Displaytime": {
                    "description": "通知持续时间.\nNotification Displaytime.",
                    "type": "Integer",
                    "min": 1000,
                    "default": 5000
                },
                "Image": {
                    "description": "通知的背景图.\nNotification image.",
                    "type": "File",
                    "default": ""
                }
            }
        },
        "Activate Window": {
            "menu": "System",
            "description": "激活指定窗口.\nActivate a KODI window",
            "callback": "activateWindow",
            "parameters":{
                "Window":{
                    "type": "Enum",
                    "options":{
                        "fullscreenvideo": "fullscreenvideo",
                        "home": "home",
                        "systeminfo": "systeminfo",
                        "settings": "settings",
                        "profiles": "profiles",
                        "filemanager": "filemanager",
                        "addonbrowser": "addonbrowser",
                        "videos": "videos",
                        "movies": "movies",
                        "movietitles": "movietitles",
                        "moviegenres": "moviegenres",
                        "tvshows": "tvshows",
                        "tvshowtitles": "tvshowtitles",
                        "musicvideos": "musicvideos",
                        "videoplaylist": "videoplaylist",
                        "music": "music",
                        "artists": "artists",
                        "albums": "albums",
                        "songs": "songs",
                        "genres": "genres",
                        "pvr": "pvr",
                        "programs": "programs",
                        "pictures": "pictures",
                        "loginscreen": "loginscreen"
                    }
                }
            }
        },
        "Fullscreen":{
            "menu": "System",
            "callback": "forceFullscreenAndClean"

        },
        "Cycle 3D Mode":{
            "menu": "3D",
            "description": "本地索引 Off→SBS→TAB→Off 循环。仅主 KODI。\nCycle Off→SBS→TAB→Off. Primary KODI only.",
            "callback": "cycleStereoMode"
        },
        "Set 3D Mode":{
            "menu": "3D",
            "description": "设置 3D 模式，同步所有 KODI。\nSet 3D mode, synced to all KODIs.",
            "callback": "setStereoMode",
            "parameters": {
                "Mode":{
                    "description": "3D模式.\n3D mode.",
                    "type": "Enum",
                    "options": {
                        "Off": "off",
                        "Side-by-Side": "sbs",
                        "Top-and-Bottom": "tab"
                    }
                },
                "Swap":{
                    "description": "交换左右眼(SBS)或上下(TAB)。Off 时无效。\n尝试通过 video.stereoscopicinvert 实现，KODI 20 可能不支持（实验性）。\nSwap L/R (SBS) or T/B (TAB). Tries video.stereoscopicinvert (experimental, KODI 20 may not support).",
                    "type": "Boolean",
                    "default": false
                }
            }
        },
        "Cycle Aspect":{
            "menu": "Aspect",
            "description": "循环切换宽高比一次。仅主 KODI。\nCycle aspect ratio once. Primary KODI only.",
            "callback": "cycleAspectRatio"
        },
        "Set Aspect":{
            "menu": "Aspect",
            "description": "循环切换宽高比，同步所有 KODI。\nCycle aspect ratio, synced to all KODIs.",
            "callback": "setAspectRatio",
            "parameters": {
                "Count":{
                    "description": "循环次数（每个循环切换一个模式）。\nNumber of cycles (each cycle advances one mode).",
                    "type": "Integer",
                    "default": 1,
                    "min": 1,
                    "max": 10
                }
            }
        },
        "Set Aspect Secondaries":{
            "menu": "Aspect",
            "description": "循环切换指定副 KODI 的宽高比。\nCycle aspect ratio for specific secondary KODIs.",
            "callback": "setAspectSecondaries",
            "parameters": {
                "Count":{
                    "description": "循环次数（每个循环切换一个模式）。\nNumber of cycles (each cycle advances one mode).",
                    "type": "Integer",
                    "default": 1,
                    "min": 1,
                    "max": 10
                },
                "Hosts":{
                    "description": "目标副 KODI 的 IP:port，每行一个。\nTarget secondary KODI IP:port, one per line.",
                    "type": "String",
                    "multiline": true,
                    "default": ""
                }
            }
        },
        "Test Launch":{
            "menu": "",
            "description": "测试 launchProcess 是否能执行命令。\nTest if launchProcess can execute commands.",
            "callback": "testLaunch"
        },
        "Debug Positions":{
            "menu": "",
            "description": "显示主副 KODI 的播放位置和漂移。\nShow primary & secondary KODI playback positions and drift.",
            "callback": "debugPositions"
        },
        "Run CoreELEC Script":{
            "menu": "System",
            "description": "在终端中运行 coreelec.sh.\nRun coreelec.sh in a terminal window.",
            "callback": "runCoreelecScript",
            "parameters": {
                "Script File":{
                    "description": "coreelec.sh 脚本文件路径.\nPath to coreelec.sh script file.",
                    "type": "File",
                    "default": ""
                },
                "Update Playlist":{
                    "description": "true=更新现有列表, false=完整初始化.\ntrue=update existing, false=full init.",
                    "type": "Boolean",
                    "default": true
                }
            }
        }
    }
}
