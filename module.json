{
    "name": "KODI",
    "type": "WebSocket Client",
    "path": "ToCenTek",
    "version": "1.2.0",
    "description": "通过 WebSocket 控制 KODI, 基于 KODI Websocket API v13.0.0 版本.\nControl KODI by Websocket. Based on KODI Websocket API v13.0.0",
    "url": "https://kodi.wiki/view/JSON-RPC_API/v13",
    "downloadURL": "",
    "hasInput": true,
    "hasOutput": true,
    "hideDefaultCommands": true,
    "hideDefaultParameters":["autoAdd", "protocol", "messageStructure", "customSeparator", "firstValueIsTheName", "useSecureConnection"],
    "defaults": {
        "Protocol": "Lines",
        "autoAdd": false,
        "useSecureConnection": false,
        "serverPath": "10.0.0.54:9090"
    },
    "parameters": {
        "Scan":{
            "type": "Trigger",
            "description": "扫描网络中的 KODI 实例,\n这需要一些时间, 且是阻塞的, 请稍等...\nScan for KODI instances on the network."
        },
        "Init": {
            "type": "Trigger",
            "description": "初始化, 加载视频播放列表.\nInitialize, load playlist."
        },
        "KODIs":{
            "type": "Container",
            "collapsed": true
        }
    },
    "values":{
        "Health":{
            "type": "String",
            "default": "--- | ---- | --- | ----",
            "readOnly": true,
            "description": "显示健康状态: \nSoc温度 | DDR 温度 | CPU 频率 | 降频等级\n温度过高会导致降频, 温度降度自动恢复\nHealth Status."
        },
        "Info":{
            "type": "Container",
            "collapsed": true,
            "isPaused":{
                "type":"Boolean",
                "readOnly": true,
                "description": "是否已暂停.\nWhether media is paused or not."
            },
            "Play/Pause":{
                "description": "切换播放/暂停.\nToggle Play/Pause.",
                "type": "Trigger"
            },
            "File":{
                "description": "当前正在播放的媒体文件路径.\nPath to the Currently Playing File.",
                "type":"String",
                "default": ""
            },
            "Playing":{
                "description": "播放进度百分比 ( % )。可拖动 seek。\nPlayback progress %. Draggable to seek.",
                "type": "Float",
                "ui": "slider",
                "min": 0,
                "max": 100,
                "default": 0
            },
            "Position":{
                "description": "当前时间.\nCurrent Playback Position.",
                "type":"String",
                "readOnly": true
            },
            "Items":{
                "description": "当前播放列表中的所有媒体项.\nAutomatically Retrieve from the Current playlist.",
                "type":"String",
                "multiline": true,
                "readOnly": true
            },
            "isLooped":{
                "type":"Boolean",
                "readOnly": true,
                "description": "false = 不循环当前媒体, 但循环列表.\ntrue = 循环播放当前媒体.\nWhether media is looped or not."
            },
            "Random":{
                "type": "Boolean",
                "readOnly": true
            },
            "Volume":{
                "description": "音量.\nCurrent Volume Level.",
                "type":"Float",
                "ui": "slider",
                "min": 0.0,
                "max": 100.0,
                "default": 80.0
            },
            "isMuted":{
                "type": "Boolean",
                "readOnly": true
            },
            "Output Resolution":{
                "description": "当前实际输出的分辨率和刷新率\nCurrent actual output resolution and refresh rate",
                "type": "String",
                "readOnly": true
            },
            "Stop":{
                "type":"Trigger",
                "description": "停止播放, 回到系统界面.\ninit 初始化后才可以重新播放\nStop Playback"
            }
        },
        "Commands":{
            "type": "Container",
            "collapsed": true,
            "Next":{
                "type":"Trigger",
                "description": "下一曲.\nNext track."
            },
            "Previous":{
                "type":"Trigger",
                "description": "上一曲.\nPrevious track."
            },
            "Seek":{
                "description":"要跳转到的百分比.\nSeek to percentage.",
                "type": "Integer",
                "default": 49
            },
            "Index":{
                "type":"Integer",
                "description": "播放指定索引的媒体项.\nPlay Media Item at Index",
                "default": 0,
                "min": 0
            },
            "File":{
                "type":"String",
                "description":"播放指定路径的媒体文件.\nPlay Media File at Path",
                "default":"/storage/videos/???.mp4"
            },     
            "Mute":{
                "type":"Boolean",
                "description":"静音\nMute"
            },
            "Audio Device":{
                "type":"Enum",
                "description":"切换音频输出.\nSwitch Audio output",
                "options": {
                    "20.5 PCM: Default": "ALSA:@",
                    "20.5 PCM: Headphone": "ALSA:sysdefault:CARD=AMLAUGESOUND",
                    "20.5 PCM: HDMI Multi Channels": "ALSA:surround71:CARD=AMLAUGESOUND,DEV=0",
                    "20.5 S/PDIF": "ALSA:iec958:CARD=AMLAUGESOUND,DEV=0",
                    "20.5 HDMI": "ALSA:hdmi:CARD=AMLAUGESOUND,DEV=0",
                    "20.5 PulseAudio: Bluetooth": "PULSE:Default",
                    "21.3 PCM: Default": "ALSA:@|Default (AML-AUGESOUND Analog)",
                    "21.3 PCM: Headphone": "ALSA:sysdefault:CARD=AMLAUGESOUND|AML-AUGESOUND",
                    "21.3 PCM: HDMI Multi Channels": "ALSA:surround71:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                    "21.3 S/PDIF": "ALSA:iec958:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                    "21.3 HDMI": "ALSA:hdmi:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                    "21.3 PulseAudio: Bluetooth": "PULSE:Default|Bluetooth Audio (PULSEAUDIO)"
                }
            },
            "Loop":{
                "type": "Enum",
                "description": "循环模式.\nLoop Mode.",
                "options": {
                    "All": "all",
                    "One": "one",
                    "Off": "off"
                }
            },
            "Random":{
                "description":"随机播放.\nShuffle",
                "type":"Boolean",
                "default":false
            },
            
            "Debug Info":{
                "description":"show debug info",
                "type":"Boolean"
            },
            "Fullscreen":{
                "description":"使视频播放界面前置",
                "type":"Trigger"
            },
            "3D":{
                "description":"切换3D模式.\nswitch 3D mode.",
                "type":"Enum",
                "options":{
                    "Off": "off",
                    "Side-by-Side": "sbs",
                    "Top-and-Bottom": "tab",
                    "Red/Cyan": "anaglyph_cyan_red",
                    "Green/Magenta": "anaglyph_green_magenta",
                    "Yellow/Blue": "anaglyph_yellow_blue",
                    "Monoscopic": "monoscopic"
                }
            }
        },
        "Player Process Info":{
                "type": "Container",
                "collapsed": true,
                "Show Info":{
                    "description":"显示播放器进程信息.\nShow Player Process Info",
                    "type":"Trigger"
                },
                "Toggle Info":{
                    "description":"切换播放器进程信息显示.\nToggle Player Process Info",
                    "type":"Trigger"
                }
        },
        "Adjust Refresh Rate":{
            "type": "Container",
            "description": "调整显示刷新率.\nAdjust Refresh Rate",
            "collapsed": true,
            "Adjust":{
                "description":"Off, 显示输出固定为桌面分辨率.\nOn start/stop, 视频开始时切换到视频分辨率, 结束时切到桌面分辨率.\nOn start, 仅在视频开始时切换.\nShow Player Process Info",
                "type":"Enum",
                "options":{
                    "On start/stop": 2,
                    "On start": 3,
                    "Off": 0
                }
            },
            "Minumise Black Bars":{
                "description":"最小化黑边.\nMinimise Black Bars",
                "type":"Integer",
                "default": 0,
                "min": 0,
                "max": 20
            },
            "Display 43 as":{
                "description":"将 4:3 视频显示为:\nNormal: 正常\nWide Zoom: 宽屏\nStretch 16:9: 拉伸为 16:9\nStretch 16:9 - Nonlinear: 拉伸为 16:9 - 非线性\nZoom: 满屏\nDisplay 4:3 videos as",
                "type": "Enum",
                "options":{
                    "Normal": 0,
                    "Wide Zoom": 3,
                    "Stretch 16:9": 4,
                    "Stretch 16:9 - Nonlinear": 7,
                    "Zoom": 1
                }
            },
            "High Quality Scaler": {
                "description":"当视频放大达到此比例(x 10)% 时启用高品质缩放器.\n",
                "type":"Integer",
                "default": 2,
                "min": 2,
                "max": 10
            },
            "Hardware Decoder": {
                "description":"使用硬件解码器.\nUse Hardware Decoder",
                "type":"Boolean",
                "default": true
            },
            "Other Blank Displays": { 
                "description":"使其它显示器为空白.\nMake other displays blank",
                "type":"Boolean",
                "default": false
            },
            "Allow 32 Refresh Rate": { 
                "description":"允许 3:2 折 刷新率.\n比如 24fps 视频在 60Hz 显示器上通过 '3帧、2帧、3帧、2帧…' 重复模式实现流畅播放, 不需要切刷新率. \n适合显示器不支持 24Hz 的情况.\nAllow 3:2 pulldown refresh rate",
                "type":"Boolean",
                "default": false
            },
            "Allow Double Refresh Rate": {
                "description":"允许 2 倍速刷新.\n24fps 用 48Hz 播, 30fps 用 60Hz 播, 每帧显示整数次. 理论上比 3:2 折 刷新率更流畅.\nAllow double refresh rate",
                "type":"Boolean",
                "default": false
            },
            "White List":{
                "description":"白名单.\nWhitelist",
                "type":"String",
                "readOnly": true
            },
            "Read Whitelist":{
                "description":"读取白名单.\nWhitelist",
                "type":"Trigger"
            },
            "Write Whitelist":{
                "description":"写入白名单, 不是所有参数都能写入, 需要显示设备时序支持.\nWhitelist",
                "type":"Enum",
                "options":{
                    "Clear Whitelist": null,
                    "1024x768@50.00": "0102407680050.00000pstd",
                    "1024x768@60.00": "0102407680060.00000pstd",
                    "1024x768@75.00": "0102407680075.00000pstd",
                    "1280x720@50.00": "0128807200050.00000pstd",
                    "1280x720@60.00": "0128807200060.00000pstd",
                    "1280x720@75.00": "0128807200075.00000pstd",
                    "1280x800@50.00": "0128808000050.00000pstd",
                    "1280x800@60.00": "0128808000060.00000pstd",
                    "1920x1080@24.00": "0192001080024.00000pstd",
                    "1920x1080@25.00": "0192001080025.00000pstd",
                    "1920x1080@29.97": "0192001080029.97000pstd",
                    "1920x1080@30.00": "0192001080030.00000pstd",
                    "1920x1080@50.00": "0192001080050.00000pstd",
                    "1920x1080@59.94": "0192001080059.94000pstd",
                    "1920x1080@60.00": "0192001080060.00000pstd",
                    "1920x1200@50.00": "0192001200050.00000pstd",
                    "1920x1200@59.94": "0192001200059.94000pstd",
                    "1920x1200@60.00": "0192001200060.00000pstd",
                    "3840x2160@24.00": "0384002160024.00000pstd",
                    "3840x2160@25.00": "0384002160025.00000pstd",
                    "3840x2160@29.97": "0384002160029.97000pstd",
                    "3840x2160@30.00": "0384002160030.00000pstd",
                    "3840x2160@50.00": "0384002160050.00000pstd",
                    "3840x2160@59.94": "0384002160059.94000pstd",
                    "3840x2160@60.00": "0384002160060.00000pstd"
                }
            },
            "Clear Whitelist":{
                "description":"清空白名单.\nClear Whitelist",
                "type":"Trigger"
            },
            "black Screen Workaround":{
                "description":"黑屏救场, 如果写入了不匹配的白名单导致黑屏, 点击切换到 1920x1080@50\nblack screen workaround",
                "type":"Trigger"
            }
        },
        "Calibration":{
            "type": "Container",
            "collapsed": true,
            "Video Calibration":{
                "description": "视频校准\nVideo Calibration",
                "type": "Trigger"
            },
            "Up": {
                "description": "上\nUp",
                "type": "Trigger"
            },
            "Down": {
                "description": "下\nDown",
                "type": "Trigger"
            },
            "Left": {
                "description": "左\nLeft",
                "type": "Trigger"
            },
            "Right": {
                "description": "右\nRight",
                "type": "Trigger"
            },
            "Enter": {
                "description": "确定\nEnter",
                "type": "Trigger"
            },
            "Back": {
                "description": "返回\nBack",
                "type": "Trigger"
            }
        },
        "Addons":{
            "type": "Container",
            "collapsed": true,
            "Autoplay Movies":{
                "type":"Container",
                "collapsed": false,
                "AutoPlay Movies":{
                    "description":"启用/禁用 Autoplay Movies 插件\nEnablee/Disable Autoplay Movies addon",
                    "type":"Boolean",
                    "default": true
                },
                "Video Folder":{
                    "description":"设置自动播放目录. 注意:\n目录中需要有视频;\n目录需要远程存在\n远程已有以下目录:\nvideos\ntvshows\nmusic\npictures\nscreenshorts\n====================\nVideos Folder",
                    "type":"String",
                    "default": "/storage/videos/"
                },
                "Text Overlaid":{
                    "description":"启动时是否显示叠加文字.\nShow Text?",
                    "type":"Boolean",
                    "default": false
                },
                "Text":{
                    "description":"启动时显示的文字.\nStartup Text",
                    "type":"String",
                    "default": "ToCenTek CoreELEC Media Center"
                },
                "Duration":{
                    "description":"文字显示时长.\nText Duration",
                    "type":"Integer",
                    "default": 2,
                    "min": 1,
                    "max": 10
                }
            }
        },
        "Power Control":{
            "type": "Container",
            "collapsed": true,
            "MAC Address":{
                "description":"MAC Address",
                "type":"String",
                "default": "XX:XX:XX:XX:XX:XX"
            },
            "Wakeup On LAN":{
                "description":"向驱动层写入WOL支持\n注意: 这是驱动层的支持, 能不能被唤醒,\n由固件底层 PHY 状态决定\n",
                "type":"Boolean",
                "default": false
            },
            "Restart KODI":{
                "description":"重启 KODI",
                "type":"Trigger"
            },
            "Standby":{
                "description":"休眠",
                "type":"Trigger"
            },
            "Reboot":{
                "description":"重启本机",
                "type":"Trigger"
            },
            "Shutdown":{
                "description":"关机",
                "type":"Trigger"
            }
        }
    },
    
    "scripts": ["kodi.js"],

    "commands": {
        "Init":{
            "menu": "",
            "description": "初始化, 加载视频播放列表\nInitialization, Load Playlist",
            "callback": "init"
        },
        "Send Raw JSON": {
            "menu": "",
            "description": "发送原始 JSON-RPC 命令到所有 KODI.\nSend raw JSON-RPC command to all KODIs.",
            "callback": "sendJSON",
            "parameters": {
                "JSON": {
                    "description": "完整且符合 KODI JSON-RPC 规范的命令字符串.\nComplete Command String Conforming to the KODI JSON-RPC Specification.",
                    "type": "String",
                    "default":"{\"jsonrpc\":\"2.0\",\"method\":\"Application.GetProperties\",\"params\":{\"properties\":[\"volume\",\"muted\"]},\"id\":\"test\"}"
                }
            }
        },

        "Index": {
            "menu": "Player",
            "description": "播放指定索引的媒体项.\nPlay Media Item at Index",
            "callback": "playIndex",
            "parameters": {
                "Index":{
                    "description": "要播放的媒体项在当前播放列表中的索引.\nIndex of the media item in the current playlist to play.",
                    "type": "Integer",
                    "default": 0,
                    "min": 0
                }
            }
        },
        "Next": {
            "menu": "Player",
            "description": "下一曲.\nNext track.",
            "callback": "nextTrack"
        },
        "Previous": {
            "menu": "Player",
            "description": "上一曲.\nPrevious track.",
            "callback": "prevTrack"
        },
        "Play||Pause": {
            "menu": "Player",
            "description": "Toggle Play/Pause\n播放/暂停",
            "callback": "playPause",
            "parameters": {
                "isPaused":{
                    "description": "是否暂停",
                    "type": "Boolean"
                }
            }
        },
        "Stop": {
            "menu": "Player",
            "description": "停止播放, 回到系统界面.\ninit 初始化后才可以重新播放\nStop Playback",
            "callback": "stopPlay"
        },
        "File": {
            "menu": "Player",
            "description": "播放指定路径的媒体文件.\nPlay Media File at Path",
            "callback": "playFile",
            "parameters": {
                "FilePath":{
                    "type": "String",
                    "default": "/storage/videos/***.mp4",
                    "description": "要播放的媒体文件的路径.\nPath to the media file to play."
                }
            }
        },

        "Mute":{
            "menu": "Volume",
            "callback": "mute",
            "parameters": {
                "Mute":{
                    "type": "Boolean"
                }
            }
        },
        "Set Volume": {
            "menu": "Volume",
            "description": "设置音量.\nSet Volume",
            "callback": "setVolume",
            "parameters": {
                "Volume":{
                    "description": "音量级别.\nVolume Level.",
                    "type": "Integer",
                    "min": 0,
                    "max": 100,
                    "default": 68
                }
            }
        },
        "Volume UP":{
            "menu": "Volume",
            "description": "音量递增.\nVolume increment",
            "callback": "volumeUP"
        },
        "Volume Down":{
            "menu": "Volume",
            "description": "音量递减.\nVolume decrement",
            "callback": "volumeDown"
        },
        "Choose Audio Output 20.5":{
            "menu": "Volume",
            "description": "选择音频输出设备.\nChoose Audio Output",
            "callback": "chooseAudioOutput",
            "parameters": {
                "Device":{
                    "description": "要选择的音频输出设备.\nChoose Audio Output",
                    "type": "Enum",
                    "options": {
                        "PCM: Default": "ALSA:@",
                        "PCM: Headphone": "ALSA:sysdefault:CARD=AMLAUGESOUND",
                        "PCM: HDMI Multi Channels": "ALSA:surround71:CARD=AMLAUGESOUND,DEV=0",
                        "S/PDIF": "ALSA:iec958:CARD=AMLAUGESOUND,DEV=0",
                        "HDMI": "ALSA:hdmi:CARD=AMLAUGESOUND,DEV=0",
                        "PulseAudio: Bluetooth": "PULSE:Default"
                    }
                }
            }
        },
        "Choose Audio Output 21.3":{
            "menu": "Volume",
            "description": "选择音频输出设备.\nChoose Audio Output",
            "callback": "chooseAudioOutput",
            "parameters": {
                "Device":{
                    "description": "要选择的音频输出设备. KODI 21.3 有效\nChoose Audio Output",
                    "type": "Enum",
                    "options": {
                        "PCM: Default": "ALSA:@|Default (AML-AUGESOUND Analog)",
                        "PCM: Headphone": "ALSA:sysdefault:CARD=AMLAUGESOUND|AML-AUGESOUND",
                        "PCM: HDMI Multi Channels": "ALSA:surround71:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                        "S/PDIF": "ALSA:iec958:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                        "HDMI": "ALSA:hdmi:CARD=AMLAUGESOUND,DEV=0|AML-AUGESOUND",
                        "PulseAudio: Bluetooth": "PULSE:Default|Bluetooth Audio (PULSEAUDIO)"
                    }
                }
            }
        },
        "Switch Audio Channels":{
            "menu": "Volume",
            "description": "切换音频声道.\nSwitch Audio Channels",
            "callback": "switchAudioChannels",
            "parameters":{
                "Channels": {
                    "type": "Enum",
                    "description": "选择音频声道.\nSelect Audio Channels",
                    "options":{
                        "2.0": 1,
                        "2.1": 2,
                        "3.0": 3,
                        "3.1": 4,
                        "4.0": 5,
                        "4.1": 6,
                        "5.0": 7,
                        "5.1": 8,
                        "7.0": 9,
                        "7.1": 10
                    }
                }
            }
        },

        "Seek": {
            "menu": "Playback",
            "description": "快进/快退.\nForward or Backward",
            "callback": "seek",
            "parameters": {
                "Step":{
                    "description": "快进或快退的时间步长, 单位为秒.\nForward: positive, e.g. 30\nBackward: negative, e.g. -30",
                    "type": "Integer",
                    "default": 30
                }
            }
        },
        "Seek To Parameters": {
            "menu": "Playback",
            "description": "跳转到百分比.\nSeek To Percentage",
            "callback": "seekToParameters",
             "parameters": {
                "Parameters": {
                    "description": "要跳转到的百分比.\nSeek to percentage.",
                    "type": "Integer",
                    "min": 0,
                    "default": 15
                }
            }
        },
        "Seek To Time": {
            "menu": "Playback",
            "description": "跳转到指定时间.\nSeek To Time",
            "callback": "seekToTime",
            "parameters": {
                "Hours":{
                    "description": "小时.\nHours.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Minutes":{
                    "description": "分钟.\nMinutes.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Seconds":{
                    "description": "秒.\nSeconds.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                },
                "Milliseconds":{
                    "description": "毫秒.\nMilliseconds.",
                    "type": "Integer",
                    "min": 0,
                    "default": 0
                }
            }
        },
        "Seek To Predefined": {
            "menu": "Playback",
            "description": "跳转到预设步进.\nSeek To Predefined Step",
            "callback": "seekToPredefined",
            "parameters": {
                "Step": {
                    "description": "预定义步进.\nPredefined step.",
                    "type": "Enum",
                    "options": {
                        "BigForward": "bigforward",
                        "SmallForward": "smallforward",
                        "BigBackward": "bigbackward",
                        "SmallBackward": "smallbackward"
                    }
                }
            }
        },
        "Loop": {
            "menu": "Playback",
            "description": "设置循环模式.\nSet Repeat Mode",
            "callback": "setLoop",
            "parameters": {
                "Mode":{
                    "description": "循环模式:\none = 循环当前媒体\noff = 不循环\nall = 循环列表\nRepeat mode:\none = Repeat Current\noff = Off\nall = Repeat All",
                    "type": "Enum",
                    "options": {
                        "One": "one",
                        "All": "all",
                        "Off": "off"
                    }
                }   
            }
        },
        "Random": {
            "menu": "Playback",
